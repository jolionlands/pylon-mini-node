# pylon-mini-node configuration
# Copy to /etc/pylon-mini-node.env and edit.

# --- required ---
PYLON_URL=http://pylon.lan:8088
PYLON_NODE_KEY=changeme
NODE_NAME=truenas-vega
NODE_BASE_URL=http://127.0.0.1:8080

# --- recommended ---
NODE_POOL=long
NODE_TIERS=fast
NODE_UPSTREAM_MODELS=gemma-4-e4b-it-iq4_xs.gguf
NODE_MAX_CONCURRENCY=4
NODE_ENGINE_KIND=llama_cpp

# --- capability metadata (optional but improves pylon's pick decisions) ---
NODE_GPU=Vega56
NODE_VRAM_GB=8

# --- live VRAM tracking (optional; requires sysfs access) ---
# Example for AMD/Vulkan setups:
# NODE_VRAM_SYSFS_CARD=/sys/class/drm/card0/device

# --- tuning (optional) ---
HEARTBEAT_SECONDS=10
LOG_LEVEL=INFO
